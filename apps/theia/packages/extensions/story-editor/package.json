{
  "name": "@forfiction/extension-story-editor",
  "keywords": ["theia-extension"],
  "version": "0.0.0",
  "files": ["lib", "src"],
  "dependencies": {
    "@theia/core": "latest",
    "@theia/editor": "latest",
    "@theia/monaco": "latest",
    "@theia/filesystem": "latest"
  },
  "devDependencies": {
    "rimraf": "latest",
    "typescript": "~5.4.5"
  },
  "scripts": {
    "prepare": "yarn run clean && yarn run build",
    "clean": "rimraf lib",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/story-editor-frontend-module"
    }
  ]
}
